#!/usr/bin/env sh
# fledge-figma — sync design tokens from Figma
# Invoked via: fledge figma <subcommand> [options]
#
# Requires FIGMA_TOKEN env var (personal access token)
# Get one at: https://www.figma.com/developers/api#access-tokens

set -e

COMMAND="${1:-help}"
FIGMA_TOKEN="${FIGMA_TOKEN:-}"
CONFIG_FILE="figma.toml"

if [ -z "$FIGMA_TOKEN" ] && [ "$COMMAND" != "help" ] && [ "$COMMAND" != "init" ]; then
    echo "Error: FIGMA_TOKEN environment variable is required."
    echo "Get a personal access token at: https://www.figma.com/developers/api#access-tokens"
    echo "Then: export FIGMA_TOKEN=your_token_here"
    exit 1
fi

figma_api() {
    URL="$1"
    curl -sf -H "X-Figma-Token: $FIGMA_TOKEN" "https://api.figma.com/v1$URL"
}

cmd_help() {
    echo "fledge figma — sync design tokens from Figma"
    echo ""
    echo "Usage: fledge figma <command> [options]"
    echo ""
    echo "Commands:"
    echo "  init                  Create a figma.toml config file"
    echo "  sync [file-key]       Sync design tokens from a Figma file"
    echo "  export [file-key]     Export component specs as JSON"
    echo "  tokens [file-key]     Extract color/typography/spacing tokens"
    echo "  help                  Show this help message"
    echo ""
    echo "Configuration:"
    echo "  Set FIGMA_TOKEN env var with your Figma personal access token."
    echo "  Optionally create a figma.toml for persistent settings."
}

cmd_init() {
    if [ -f "$CONFIG_FILE" ]; then
        echo "figma.toml already exists."
        exit 1
    fi
    cat > "$CONFIG_FILE" << 'TOML'
# Figma plugin configuration for fledge
# Docs: https://github.com/CorvidLabs/fledge-plugin-figma

[figma]
# Your Figma file key (from the URL: figma.com/file/<KEY>/...)
file_key = ""

# Output directory for generated token files
output_dir = "tokens"

# Output format: "css", "scss", "json", "tailwind"
format = "css"

[figma.tokens]
# Which token types to extract
colors = true
typography = true
spacing = true
shadows = true
border_radius = true

[figma.export]
# Component export settings
format = "json"
output_dir = "specs"
TOML
    echo "✓ Created figma.toml — edit it with your Figma file key."
}

cmd_sync() {
    FILE_KEY="$1"

    if [ -z "$FILE_KEY" ] && [ -f "$CONFIG_FILE" ]; then
        FILE_KEY=$(grep 'file_key' "$CONFIG_FILE" 2>/dev/null | head -1 | sed 's/.*= *"\(.*\)"/\1/')
    fi

    if [ -z "$FILE_KEY" ]; then
        echo "Error: No file key provided."
        echo "Usage: fledge figma sync <file-key>"
        echo "Or set file_key in figma.toml"
        exit 1
    fi

    echo "🎨 Fetching Figma file $FILE_KEY..."
    RESPONSE=$(figma_api "/files/$FILE_KEY")

    if [ $? -ne 0 ] || [ -z "$RESPONSE" ]; then
        echo "Error: Failed to fetch Figma file. Check your FIGMA_TOKEN and file key."
        exit 1
    fi

    FILE_NAME=$(echo "$RESPONSE" | grep -o '"name":"[^"]*"' | head -1 | sed 's/"name":"//;s/"//')
    echo "✓ Connected to: $FILE_NAME"

    cmd_tokens "$FILE_KEY"
}

cmd_tokens() {
    FILE_KEY="$1"
    OUTPUT_DIR="tokens"
    FORMAT="css"

    if [ -f "$CONFIG_FILE" ]; then
        CONFIGURED_DIR=$(grep 'output_dir' "$CONFIG_FILE" 2>/dev/null | head -1 | sed 's/.*= *"\(.*\)"/\1/')
        CONFIGURED_FMT=$(grep 'format' "$CONFIG_FILE" 2>/dev/null | head -1 | sed 's/.*= *"\(.*\)"/\1/')
        [ -n "$CONFIGURED_DIR" ] && OUTPUT_DIR="$CONFIGURED_DIR"
        [ -n "$CONFIGURED_FMT" ] && FORMAT="$CONFIGURED_FMT"
    fi

    if [ -z "$FILE_KEY" ] && [ -f "$CONFIG_FILE" ]; then
        FILE_KEY=$(grep 'file_key' "$CONFIG_FILE" 2>/dev/null | head -1 | sed 's/.*= *"\(.*\)"/\1/')
    fi

    if [ -z "$FILE_KEY" ]; then
        echo "Error: No file key provided."
        exit 1
    fi

    echo "🔍 Extracting design tokens from $FILE_KEY..."
    STYLES=$(figma_api "/files/$FILE_KEY/styles")

    if [ $? -ne 0 ] || [ -z "$STYLES" ]; then
        echo "Error: Failed to fetch styles."
        exit 1
    fi

    mkdir -p "$OUTPUT_DIR"

    case "$FORMAT" in
        css)
            OUTPUT_FILE="$OUTPUT_DIR/tokens.css"
            echo "/* Generated by fledge-plugin-figma — do not edit manually */" > "$OUTPUT_FILE"
            echo "/* Source: https://www.figma.com/file/$FILE_KEY */" >> "$OUTPUT_FILE"
            echo ":root {" >> "$OUTPUT_FILE"
            echo "$STYLES" | grep -o '"name":"[^"]*"' | sed 's/"name":"//;s/"//' | while read -r name; do
                CSS_NAME=$(echo "$name" | tr '[:upper:]' '[:lower:]' | tr ' /' '-' | tr -cd 'a-z0-9-')
                echo "  --$CSS_NAME: /* TODO: map from Figma */;" >> "$OUTPUT_FILE"
            done
            echo "}" >> "$OUTPUT_FILE"
            echo "✓ Wrote CSS tokens to $OUTPUT_FILE"
            ;;
        json)
            OUTPUT_FILE="$OUTPUT_DIR/tokens.json"
            echo "$STYLES" > "$OUTPUT_FILE"
            echo "✓ Wrote JSON tokens to $OUTPUT_FILE"
            ;;
        *)
            echo "✓ Fetched styles (format '$FORMAT' — full extraction coming soon)"
            echo "$STYLES" > "$OUTPUT_DIR/tokens.json"
            ;;
    esac
}

cmd_export() {
    FILE_KEY="$1"

    if [ -z "$FILE_KEY" ] && [ -f "$CONFIG_FILE" ]; then
        FILE_KEY=$(grep 'file_key' "$CONFIG_FILE" 2>/dev/null | head -1 | sed 's/.*= *"\(.*\)"/\1/')
    fi

    if [ -z "$FILE_KEY" ]; then
        echo "Error: No file key provided."
        exit 1
    fi

    echo "📦 Exporting component specs from $FILE_KEY..."
    COMPONENTS=$(figma_api "/files/$FILE_KEY/components")

    if [ $? -ne 0 ] || [ -z "$COMPONENTS" ]; then
        echo "Error: Failed to fetch components."
        exit 1
    fi

    EXPORT_DIR="specs"
    if [ -f "$CONFIG_FILE" ]; then
        CONFIGURED=$(grep -A5 '\[figma.export\]' "$CONFIG_FILE" 2>/dev/null | grep 'output_dir' | sed 's/.*= *"\(.*\)"/\1/')
        [ -n "$CONFIGURED" ] && EXPORT_DIR="$CONFIGURED"
    fi

    mkdir -p "$EXPORT_DIR"
    echo "$COMPONENTS" > "$EXPORT_DIR/components.json"
    echo "✓ Exported components to $EXPORT_DIR/components.json"
}

case "$COMMAND" in
    help)    cmd_help ;;
    init)    cmd_init ;;
    sync)    cmd_sync "$2" ;;
    tokens)  cmd_tokens "$2" ;;
    export)  cmd_export "$2" ;;
    *)
        echo "Unknown command: $COMMAND"
        echo "Run 'fledge figma help' for usage."
        exit 1
        ;;
esac
